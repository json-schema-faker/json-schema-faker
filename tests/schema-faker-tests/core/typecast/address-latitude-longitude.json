[
  {
    "description": "should typecast faker.location.latitude and faker.location.longitude when generated value type is different than defined",
    "tests": [
      {
        "description": "should generate the value with default type provided by faker.js (no explicit typedef)",
        "schema": {
          "faker": "location.longitude"
        },
        "require": "core/extend/faker-extend",
        "valid": true
      },
      {
        "description": "should cast to number",
        "schema": {
          "type": "number",
          "faker": "location.longitude"
        },
        "require": "core/extend/faker-extend",
        "valid": true
      },
      {
        "description": "should cast to integer",
        "schema": {
          "type": "integer",
          "faker": "location.longitude"
        },
        "require": "core/extend/faker-extend",
        "valid": true
      },
      {
        "description": "should cast array elements to number",
        "schema": {
          "type": "array",
          "prefixItems": [
            {
              "type": "number",
              "faker": "location.latitude"
            },
            {
              "type": "number",
              "faker": "location.longitude"
            }
          ]
        },
        "require": "core/extend/faker-extend",
        "valid": true
      },
      {
        "description": "should cast object properties values to number",
        "schema": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "description": "A geographical coordinate",
          "type": "object",
          "properties": {
            "latitude": {
              "type": "number",
              "faker": "location.latitude"
            },
            "longitude": {
              "type": "number",
              "faker": "location.longitude"
            }
          },
          "required": [
            "latitude",
            "longitude"
          ]
        },
        "require": "core/extend/faker-extend",
        "valid": true
      }
    ]
  }
]
