[
  {
    "description": "Issue #678 - Support tuples via prefixItems (JSON Schema 2020-12)",
    "tests": [
      {
        "description": "should generate a tuple array with prefixItems",
        "schema": {
          "type": "array",
          "prefixItems": [
            { "type": "number" },
            { "type": "string" },
            { "enum": ["Street", "Avenue", "Boulevard"] },
            { "enum": ["NW", "NE", "SW", "SE"] }
          ]
        },
        "valid": true
      },
      {
        "description": "should generate a tuple with additional items allowed",
        "schema": {
          "type": "array",
          "prefixItems": [
            { "type": "integer" },
            { "type": "string" }
          ],
          "items": { "type": "boolean" }
        },
        "valid": true
      },
      {
        "description": "should generate a tuple with no additional items",
        "schema": {
          "type": "array",
          "prefixItems": [
            { "type": "string" },
            { "type": "number" }
          ],
          "items": false
        },
        "valid": true
      }
    ]
  }
]
