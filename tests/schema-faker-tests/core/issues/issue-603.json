[
  {
    "description": "Fields missing when using 'allOf' inside '$defs'",
    "tests": [
      {
        "description": "should eventually generate missing props",
        "schema": {
          "allOf": [
            {
              "properties": {
                "a": {
                  "type": "string"
                }
              },
              "required": [
                "a"
              ]
            },
            {
              "$ref": "#/$defs/foo"
            },
            {
              "$ref": "#/$defs/bar"
            }
          ],
          "$defs": {
            "foo": {
              "allOf": [
                {
                  "properties": {
                    "b": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "b"
                  ]
                },
                {
                  "properties": {
                    "c": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "c"
                  ]
                }
              ]
            },
            "bar": {
              "properties": {
                "d": {
                  "type": "string"
                }
              },
              "required": [
                "d"
              ]
            }
          }
        },
        "valid": true
      }
    ]
  }
]
