[
  {
    "description": "sub-schema mixins",
    "schemas": [
      {
        "type": "object",
        "$defs": {
          "inner": {
            "aString": {
              "allOf": [
                { "type": "string" },
                { "$ref": "#/$defs/rules" }
              ]
            }
          },
          "rules": {
            "allOf": [
              { "$ref": "#/$defs/twoChars" },
              { "$ref": "#/$defs/asEmail" }
            ]
          },
          "twoChars": {
            "minLength": 10
          },
          "asEmail": {
            "faker": "internet.email"
          }
        },
        "properties": {
          "anArray": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "allOf": [
                  { "$ref": "#/$defs/inner" }
                ]
              },
              "required": ["aString"]
            }
          }
        },
        "required": ["anArray"]
      }
    ],
    "tests": [
      {
        "description": "should combine recursively",
        "schema": "schemas.0",
        "valid": true
      }
    ]
  }
]
