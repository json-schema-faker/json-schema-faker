[
  {
    "description": "Issue #736 - OpenAPI schemas with #/components/schemas/ $ref resolution",
    "tests": [
      {
        "description": "OpenAPI-style $ref resolved via refs map (Category embedded)",
        "schema": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "category": { "$ref": "#/components/schemas/Category" },
            "status": { "type": "string", "enum": ["available", "pending", "sold"] }
          }
        },
        "refs": [
          {
            "id": "#/components/schemas/Category",
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          }
        ],
        "valid": true
      },
      {
        "description": "OpenAPI-style nested $ref chain resolved via refs map",
        "schema": {
          "type": "object",
          "required": ["name", "photoUrls"],
          "properties": {
            "name": { "type": "string" },
            "photoUrls": { "type": "array", "items": { "type": "string" } },
            "category": { "$ref": "#/components/schemas/Category" },
            "status": { "type": "string", "enum": ["available", "pending", "sold"] }
          }
        },
        "refs": [
          {
            "id": "#/components/schemas/Category",
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          }
        ],
        "valid": true
      },
      {
        "description": "workaround: rewrite OpenAPI $ref paths using $defs",
        "schema": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "category": { "$ref": "#/$defs/Category" },
            "status": { "type": "string", "enum": ["available", "pending", "sold"] }
          },
          "$defs": {
            "Category": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" }
              }
            }
          }
        },
        "valid": true
      }
    ]
  }
]
