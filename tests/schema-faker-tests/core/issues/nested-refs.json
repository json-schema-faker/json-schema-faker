{
  "description": "nested $refs",
  "tests": [
    {
      "description": "should follow nested $refs in synchronous mode",
      "sync": true,
      "schema": {
        "type": "object",
        "properties": {
          "hello": {
            "$ref": "#/$defs/middle"
          }
        },
        "required": ["hello"],
        "$defs": {
          "middle": {
            "$ref": "#/$defs/world"
          },
          "world": {
            "type": "string",
            "const": "world!"
          }
        }
      },
      "equal": {
        "hello": "world!"
      }
    }
  ]
}
