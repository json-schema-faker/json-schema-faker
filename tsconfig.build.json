{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["bun"],
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts", "bin/**/*.ts"],
  "exclude": ["tests/**/*", "node_modules"]
}
